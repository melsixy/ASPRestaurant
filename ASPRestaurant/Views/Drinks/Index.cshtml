@model IEnumerable<ASPRestaurant.Data.Drink>

@{
    ViewData["Title"] = "Напитки";
}

<h1 class="page-title">Напитки</h1>

<p class="text-center">
    <a asp-action="Create" class="btn btn-primary">+ Добави напитка</a>
</p>

@{
    var categories = Model
        .GroupBy(x => x.TypeOrders?.Name ?? "Без категория");
}

@foreach (var category in categories)
{
    <h2 class="section-title">@category.Key</h2>

    <div class="menu-grid">

        @foreach (var item in category)
        {
            <div class="menu-card">

                <img src="@item.CoverImage" />

                <div class="menu-body">

                    <h3>@item.Name</h3>

                    <p class="text-muted">@item.Description</p>

                    <p>Количество: <b>@item.Litre</b></p>

                    <p class="price">@item.Price лв</p>

                    <div class="actions">

                        <a asp-action="Details"
                           asp-route-id="@item.Id"
                           class="btn btn-primary btn-sm">
                            Детайли
                        </a>

                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-warning btn-sm">
                                Редактирай
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-danger btn-sm">
                                Изтрий
                            </a>
                        }

                    </div>

                </div>

            </div>
        }

    </div>
}