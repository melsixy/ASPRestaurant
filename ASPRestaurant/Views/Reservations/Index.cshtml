@model IEnumerable<ASPRestaurant.Data.Reservation>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                Брой клиенти
                @* @Html.DisplayNameFor(model => model.NumberOfPeople) *@
            </th>
            <th>
                Дата
               @*  @Html.DisplayNameFor(model => model.Date) *@
            </th>
            <th>
                Час
                @* @Html.DisplayNameFor(model => model.Time) *@
            </th>
            <th>
                Клиент
               @*  @Html.DisplayNameFor(model => model.Clients) *@
            </th>
            <th>
                Маса
               @*  @Html.DisplayNameFor(model => model.Tables) *@
            </th>
            <th>
                Регистриран в
                @* @Html.DisplayNameFor(model => model.RegisterOn) *@
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.NumberOfPeople)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Date)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Time)
            </td>
            <td>
                @(item.Clients.UserName + " "+item.Clients.LastName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Tables.Description)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.RegisterOn)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
