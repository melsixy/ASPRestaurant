@model IEnumerable<ASPRestaurant.Data.Table>

@{
	ViewData["Title"] = "Маси";
}

<h1 class="page-title">Маси</h1>

<div class="stats">
	<div class="stat free">
		Свободни: @Model.Count(x => x.IsAvailable)
	</div>

	<div class="stat busy">
		Заети: @Model.Count(x => !x.IsAvailable)
	</div>
</div>

@if (User.IsInRole("Admin"))
{
	<p class="text-center">
		<a asp-action="Create" class="btn btn-primary">+ Добави маса</a>
	</p>
}

<div class="tables-grid">

	@foreach (var item in Model)
	{
		<div class="table-card">

			<h3>Маса №@item.TableNumber</h3>

			<p>@item.Description</p>

			<p>Места: <b>@item.Count</b></p>

			<p>
				@if (item.Reservations != null &&
							item.Reservations.Any(r => r.Date.Date == DateTime.Today))
				{
					<span class="busy">Заета</span>
				}
				else
				{
					<span class="free">Свободна</span>
				}
			</p>

			<div class="actions">

				@if (User.IsInRole("Admin"))
				{
					<a asp-action="Edit" asp-route-id="@item.Id">Редактирай</a>
					<a asp-action="Delete" asp-route-id="@item.Id">Изтрий</a>
				}

				<a asp-action="Details" asp-route-id="@item.Id">Детайли</a>

				@if (User.Identity.IsAuthenticated)
				{
					<a asp-controller="Reservations"
					   asp-action="Create"
					   asp-route-tableId="@item.Id"
					   class="reserve-btn">
						Резервирай
					</a>
				}

			</div>
		</div>
	}

</div>