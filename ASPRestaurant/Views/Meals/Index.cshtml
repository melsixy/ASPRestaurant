@model IEnumerable<ASPRestaurant.Data.Meal>

@{
	ViewData["Title"] = "Index";
}

<h1>Меню-напитки</h1>
<p>
	<a asp-action="Create">Добави нов запис</a>
</p>
<table class="table">
	<thead>
		<tr>
			<th>
				Име на ястие
			</th>
			<th>
				Алергени
			</th>
			<th>
				Грамаж
			</th>
			<th>
				Цена
			</th>
			<th>
				Картина
			</th>
			<th>
				@Html.DisplayNameFor(model => model.TypeOrders)
			</th>
			<th></th>
		</tr>
	</thead>
	<tbody>
		@foreach (var item in Model)
		{
			<tr>
				<td>
					@Html.DisplayFor(modelItem => item.Name)
				</td>
				<td>
					@Html.DisplayFor(modelItem => item.Alergens)
				</td>
				<td>
					@Html.DisplayFor(modelItem => item.Grammage)
				</td>
				<td>
					@Html.DisplayFor(modelItem => item.Price)
				</td>
				<td>
					<img src="@item.CoverImage" width="100" />
				</td>
				<td>
					@Html.DisplayFor(modelItem => item.TypeOrders.Id)
				</td>
				<td>
					@if (User.IsInRole("Admin"))
					{
						<a asp-action="Edit" asp-route-id="@item.Id">Редактирай</a>
						<a asp-action="Delete" asp-route-id="@item.Id"> | Изтрий | </a>
					}
					<a asp-action="Details" asp-route-id="@item.Id">Детайли</a>
				</td>
			</tr>
		}
	</tbody>
</table>
