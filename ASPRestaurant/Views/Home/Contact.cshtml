@{
    ViewData["Title"] = "Контакти";
}

<h1 class="page-title">Контакти</h1>

<div class="contact-page">

    <!-- Лява част -->
    <div class="contact-box">

        <h3>📍 Кулинарницата</h3>

        <p>София, България</p>

        <p>📞 +359 888 123 456</p>

        <p>✉️ info@kulinarnicata.bg</p>

        <p>⏰ Пон-Пет: 10:00 - 22:00</p>
        <p>⏰ Съб-Нед: 11:00 - 23:00</p>

    </div>

    <!-- Форма -->
    <div class="contact-form">

        <h3>Изпрати съобщение</h3>

        <form>

            <input type="text" placeholder="Име" class="form-control" />

            <input type="email" placeholder="Имейл" class="form-control" />

            <textarea placeholder="Съобщение" class="form-control"></textarea>

            <button class="btn btn-primary w-100">
                Изпрати
            </button>

        </form>

    </div>

</div>

<!-- Карта -->
<div class="map-box">
    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2934.0!2d23.3219!3d42.6977!2m3!1f0!2f0!3f0!3m2!1i1024!2i768"
            width="100%" height="300" style="border:0;" allowfullscreen="">
    </iframe>
</div>

