@model IEnumerable<ASPRestaurant.Data.TypeOrder>

@{
    ViewData["Title"] = "Index";
}

<h1>Категории</h1>
<p>
    <a asp-action="Create">Добави нов запис</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                Име
            </th>
            <th>
                Регистриран в
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.RegisterOn)
            </td>
                <td>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id">Редактирай</a>
                        <a asp-action="Delete" asp-route-id="@item.Id"> | Изтрий | </a>
                    }
                    <a asp-action="Details" asp-route-id="@item.Id">Детайли</a>
                </td>
        </tr>
}
    </tbody>
</table>
