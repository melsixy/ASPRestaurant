<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Кулинарницата</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark" style="background-color: #89CFF0;">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">Кулинарницата</a>
            @* <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button> *@
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Начало</a></li>
                    <li class="nav-item"><a class="nav-link" href="/reservations">Резервации</a></li>
                    <li class="nav-item"><a class="nav-link" href="/tables">Маси</a></li>
                    <li class="nav-item"><a class="nav-link" href="/meals">Ястия</a></li>
                    <li class="nav-item"><a class="nav-link" href="/drinks">Напитки</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/Gallery">Галерия</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/Contact">Контакти</a></li>

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link text-success" href="#">Здравей, @User.Identity.Name</a>
                        </li>
                        <li class="nav-item">
                            <form method="post" action="/Identity/Account/Logout">
                                <button type="submit" class="nav-link btn btn-link">Logout</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" href="/Identity/Account/Login">Login</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Identity/Account/Register">Register</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="bg-dark text-white text-center p-4 mt-5">
        &copy; 2026 Кулинарницата.
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Добавяме секция Scripts, незадължителна -->
    @RenderSection("Scripts", required: false)
</body>
</html>

